{
  "name": "@meatcar/agent-hud",
  "version": "0.2.0",
  "description": "Fast statusline HUD for Claude Code",
  "license": "MIT",
  "repository": "github:meatcar/agent-hud",
  "bin": {
    "agent-hud": "src/index.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "bun test",
    "lint": "oxlint && fallow",
    "format": "treefmt -q",
    "check": "bun run lint && bun run format --ci",
    "build": "bun build --target=bun --banner='#!/usr/bin/env bun' --outfile=dist/agent-hud.ts src/index.ts",
    "deploy": "bun run build && cp dist/agent-hud.ts $HOME/.claude/agent-hud.ts",
    "screenshots": "bash scripts/screenshots.sh",
    "bench": "bash bench/run.sh",
    "bench:analyze": "bun run bench/analyze.ts"
  },
  "devDependencies": {
    "@tsconfig/bun": "^1.0.10",
    "@types/bun": "latest",
    "fallow": "^2.66.2",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
